# Lumas Configuration — Environment Variables
# Copy this to .env and fill in your values.
# Environment variables override config.json values.

# Engine: "local" or "online"
# LUMAS_ENGINE=local

# Path to the local GGUF model file
# LUMAS_MODEL_PATH=models/gemma-3-270m-int4.gguf

# OpenAI API key (required if engine is "online")
OPENAI_API_KEY=

# LUMAS_TEMPERATURE=0.7
# LUMAS_CONTEXT_SIZE=2048
# LUMAS_HOST=127.0.0.1
# LUMAS_PORT=8765
